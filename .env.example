OPENROUTER_API_KEY=your_openrouter_key_here
DATABASE_URL=postgresql://beacon:beacon@db:5432/beacon
PORT=3001

# Optional: GitHub token for higher rate limits (5000 req/hr vs 60 without token)
# GITHUB_TOKEN=
# Optional: override the default model
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: comma-separated fallback models tried on provider errors
# OPENROUTER_MODEL_FALLBACKS=google/gemini-2.0-flash-001,mistralai/mistral-small
# Optional: max total tokens per analysis run (default 150000)
# AGENT_TOKEN_BUDGET=150000
# Optional: per-IP requests/min on mutating routes (default 20)
# RATE_LIMIT_PER_MIN=20
